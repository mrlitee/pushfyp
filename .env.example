# Konfigurasi akun Threads untuk auto push FYP
# Format: username:password (satu akun per baris)
# Tambahkan akun sebanyak yang diperlukan

ACCOUNTS=username1:password1,username2:password2,username3:password3

# Pengaturan
HEADLESS=true
DELAY_MIN=5
DELAY_MAX=15
LIKE=true
REPOST=true
COMMENT=true

# Komentar random (pisahkan dengan |)
COMMENTS=keren banget!|mantap|bagus sekali|suka ini|top!|amazing|nice post|fire!
